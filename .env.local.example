# ─── Snowflake Connection ───
# Find Blue uses these to connect to your Snowflake warehouse.
# All credentials are server-side only (API Routes), never exposed to the browser.

SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USERNAME=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=URBAN_MISMATCH_AI
SNOWFLAKE_SCHEMA=ANALYTICS

# 소상공인시장진흥공단_상가(상권)정보_API 키 발급: https://www.data.go.kr/data/15012005/openapi.do
PUB_DATA_API_KEY=your_api_key_here
